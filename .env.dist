# User OAuth Token (starts with xoxp-)
SLACK_MCP_XOXP_TOKEN="" # Replace with your user OAuth token

# Bot OAuth Token (starts with xoxb-)
SLACK_MCP_XOXB_TOKEN="" # Replace with your bot token

# API Key for Bearer token authentication (SSE/HTTP modes)
SLACK_MCP_API_KEY="" # Replace with your actual API key

# TLS configuration for SSE/HTTP server
# SLACK_MCP_TLS_CERT="" # Path to TLS certificate file
# SLACK_MCP_TLS_KEY=""  # Path to TLS private key file

# CORS origin restriction for SSE/HTTP server
# When set, only requests from this origin are allowed. When unset, no CORS headers are sent (same-origin only).
# SLACK_MCP_CORS_ORIGIN="" # e.g. "https://myapp.example.com"

# Tool configuration for destructive tools (set to "true", "1", comma-separated channel IDs, or "!"-prefixed blocklist)
# SLACK_MCP_ADD_MESSAGE_TOOL=""    # Enable sending messages
# SLACK_MCP_EDIT_MESSAGE_TOOL=""   # Enable editing messages
# SLACK_MCP_DELETE_MESSAGE_TOOL="" # Enable deleting messages
# SLACK_MCP_USERGROUP_WRITE_TOOL="" # Enable usergroup create/update/members tools
# SLACK_MCP_MARK_TOOL=""            # Enable mark-as-read tool